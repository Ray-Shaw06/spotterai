# SpotterAI environment variables
# ---------------------------------
# Copy this file to ".env" (which is git-ignored) and paste in your own key.
#
# Get a FREE Gemini API key — no credit card required — at:
#   https://aistudio.google.com/app/apikey
#
# The key is read ONLY by the serverless function (api/generate.js) and is
# never exposed to the browser.

GEMINI_API_KEY=your_gemini_api_key_here
